[gd_resource type="ShaderMaterial" format=3 uid="uid://cyrraygbfa720"]

[sub_resource type="Shader" id="Shader_ko2wl"]
code = "shader_type spatial;
render_mode cull_front, unshaded;

uniform vec4 outline_color : source_color = vec4(0, 0, 0, 1);
uniform float outline_width = 1.0;

void vertex() {
    // Standard approach: push vertices out along their normal vectors
    vec4 clip_position = PROJECTION_MATRIX * (MODELVIEW_MATRIX * vec4(VERTEX, 1.0));
    vec3 clip_normal = mat3(PROJECTION_MATRIX) * (mat3(MODELVIEW_MATRIX) * NORMAL);
    
    // Offset the position based on the normal and outline width
    clip_position.xy += clip_normal.xy * outline_width * clip_position.w * 0.001;
    POSITION = clip_position;
}

void fragment() {
    ALBEDO = outline_color.rgb;
    ALPHA = outline_color.a;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_ko2wl")
shader_parameter/outline_color = Color(0, 0, 0, 1)
shader_parameter/outline_width = 50.0
